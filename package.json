{
  "name": "pharma-sales-analyzer",
  "version": "1.0.0",
  "type": "module",
  "description": "A web platform for analyzing pharmaceutical sales data using AI.",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node node_modules/nodemon/bin/nodemon.js",
    "server:once": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "keywords": [
    "pharmaceutical",
    "sales",
    "data analysis",
    "AI",
    "Excel"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
