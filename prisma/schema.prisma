// ============================================================
// Prisma Schema - Medical Representative Sales Management
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  // Legacy roles: "admin" | "manager" | "user"
  // New roles:    "office_manager" | "office_hr" | "office_employee"
  //               "company_manager" | "supervisor" | "product_manager" | "team_leader"
  //               "scientific_rep" | "commercial_supervisor" | "commercial_team_leader" | "commercial_rep"
  isActive     Boolean  @default(true)
  displayName  String?
  phone        String?
  linkedRepId  Int?
  officeId     Int? // المكتب العلمي المرتبط به
  permissions  String? // JSON: { pages:[], hiddenFields:[], features:[] }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // New office link
  office    ScientificOffice?         @relation(fields: [officeId], references: [id])
  // Legacy links
  linkedRep ScientificRepresentative? @relation("UserLinkedRep", fields: [linkedRepId], references: [id])

  areas          Area[]
  items          Item[]
  companies      Company[]
  customers      Customer[]
  medicalReps    MedicalRepresentative[]
  scientificReps ScientificRepresentative[]
  uploadedFiles  UploadedFile[]
  sales          Sale[]
  doctors        Doctor[]
  monthlyPlans   MonthlyPlan[]
  assignedPlans  MonthlyPlan[]              @relation("AssignedPlans")
  doctorVisits   DoctorVisit[]
  pharmacyVisits PharmacyVisit[]

  // Multi-tenant assignments
  companyAssignments  UserCompanyAssignment[]
  lineAssignments     UserLineAssignment[]
  itemAssignments     UserItemAssignment[]
  areaAssignments     UserAreaAssignment[]
  managersOfUser      UserManagerAssignment[]     @relation("UserSubordinates")
  subordinatesOfUser  UserManagerAssignment[]     @relation("UserManagers")
  interactionAsActor  UserInteractionPermission[] @relation("InteractionActor")
  interactionAsTarget UserInteractionPermission[] @relation("InteractionTarget")
  invoiceSheets       InvoiceSheet[]

  @@index([officeId])
  @@map("users")
}

// ─── Medical Representative ──────────────────────────────────
model MedicalRepresentative {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  // Relations
  areas          RepresentativeArea[]
  items          RepresentativeItem[]
  sales          Sale[]
  scientificReps ScientificRepCommercial[]

  @@unique([name, userId])
  @@index([userId])
  @@map("medical_representatives")
}

// ─── Area ────────────────────────────────────────────────────
model Area {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  userId   Int?
  user     User?             @relation(fields: [userId], references: [id])
  officeId Int?
  office   ScientificOffice? @relation("OfficeAreas", fields: [officeId], references: [id])

  // Relations
  representatives     RepresentativeArea[]
  scientificReps      ScientificRepArea[]
  sales               Sale[]
  doctors             Doctor[]
  userAreaAssignments UserAreaAssignment[]
  pharmacyVisits      PharmacyVisit[]

  @@unique([name, userId])
  @@index([userId])
  @@index([officeId])
  @@map("areas")
}

// ─── Company (Pharmaceutical company) ───────────────────────
model Company {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  items          Item[]
  scientificReps ScientificRepCompany[]

  @@unique([name, userId])
  @@index([userId])
  @@map("companies")
}

// ─── Item (Drug / Product) ───────────────────────────────────
model Item {
  id                Int      @id @default(autoincrement())
  name              String   // الاسم التجاري
  scientificName    String?  // الاسم العلمي
  dosage            String?  // الجرعة الدوائية
  form              String?  // الشكل الدوائي (أقراص، كبسول، شراب...)
  price             Float?   // السعر
  scientificMessage String?  // المسج العلمي
  createdAt         DateTime @default(now())

  userId              Int?
  user                User?              @relation(fields: [userId], references: [id])
  companyId           Int?
  company             Company?           @relation(fields: [companyId], references: [id])
  scientificCompanyId Int?
  scientificCompany   ScientificCompany? @relation("CompanyItems", fields: [scientificCompanyId], references: [id])

  // Relations
  representatives     RepresentativeItem[]
  scientificReps      ScientificRepItem[]
  sales               Sale[]
  doctors             Doctor[]
  doctorVisits        DoctorVisit[]
  planEntryItems      PlanEntryItem[]
  lineItems           ProductLineItem[]
  userItemAssignments UserItemAssignment[]
  pharmacyVisitItems  PharmacyVisitItem[]

  @@unique([name, userId])
  @@index([userId])
  @@index([companyId])
  @@index([scientificCompanyId])
  @@map("items")
}

// ─── Many-to-Many: Representative ↔ Area ─────────────────────
// Empty = "All Areas" (handled in service layer)
model RepresentativeArea {
  representativeId Int
  areaId           Int
  assignedAt       DateTime @default(now())

  representative MedicalRepresentative @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  area           Area                  @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([representativeId, areaId])
  @@map("representative_areas")
}

// ─── Many-to-Many: Representative ↔ Item ─────────────────────
// Empty = "All Items" (handled in service layer)
model RepresentativeItem {
  representativeId Int
  itemId           Int
  assignedAt       DateTime @default(now())

  representative MedicalRepresentative @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  item           Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([representativeId, itemId])
  @@map("representative_items")
}

// ─── Customer (Pharmacy / Clinic / Hospital) ────────────────
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  sales Sale[]

  @@unique([name, userId])
  @@index([userId])
  @@map("customers")
}

// ─── Sale ────────────────────────────────────────────────────
model Sale {
  id               Int      @id @default(autoincrement())
  representativeId Int
  areaId           Int
  itemId           Int
  customerId       Int?
  quantity         Int
  totalValue       Float
  saleDate         DateTime @default(now())
  uploadedFileId   Int?
  createdAt        DateTime @default(now())
  rawData          String? // JSON-encoded original Excel row
  recordType       String   @default("sale") // "sale" | "return"

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  // Relations
  representative MedicalRepresentative @relation(fields: [representativeId], references: [id])
  area           Area                  @relation(fields: [areaId], references: [id])
  item           Item                  @relation(fields: [itemId], references: [id])
  customer       Customer?             @relation(fields: [customerId], references: [id])
  uploadedFile   UploadedFile?         @relation(fields: [uploadedFileId], references: [id])

  // Indexes for performance
  @@index([representativeId])
  @@index([areaId])
  @@index([itemId])
  @@index([customerId])
  @@index([createdAt])
  @@index([saleDate])
  @@index([userId])
  @@map("sales")
}

// ─── Uploaded File ───────────────────────────────────────────
model UploadedFile {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  rowCount     Int
  uploadedAt   DateTime @default(now())
  uploadedBy   String?
  fileType     String   @default("sales") // "sales" | "returns"

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  sales Sale[]

  @@index([userId])
  @@map("uploaded_files")
}

// ─── Scientific Representative (مندوب علمي) ──────────────────
model ScientificRepresentative {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  company   String?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  // Assigned areas, items, companies, and commercial reps
  areas          ScientificRepArea[]
  items          ScientificRepItem[]
  companies      ScientificRepCompany[]
  commercialReps ScientificRepCommercial[]
  monthlyPlans   MonthlyPlan[]
  doctorVisits   DoctorVisit[]
  pharmacyVisits PharmacyVisit[]
  linkedUsers    User[]                    @relation("UserLinkedRep")

  @@unique([name, userId])
  @@index([userId])
  @@map("scientific_representatives")
}

// ─── ScientificRep ↔ Area ────────────────────────────────────
model ScientificRepArea {
  scientificRepId Int
  areaId          Int
  assignedAt      DateTime @default(now())

  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id], onDelete: Cascade)
  area          Area                     @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([scientificRepId, areaId])
  @@map("scientific_rep_areas")
}

// ─── ScientificRep ↔ Item ────────────────────────────────────
model ScientificRepItem {
  scientificRepId Int
  itemId          Int
  assignedAt      DateTime @default(now())

  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id], onDelete: Cascade)
  item          Item                     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([scientificRepId, itemId])
  @@map("scientific_rep_items")
}

// ─── ScientificRep ↔ Company ─────────────────────────────────
model ScientificRepCompany {
  scientificRepId Int
  companyId       Int
  assignedAt      DateTime @default(now())

  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id], onDelete: Cascade)
  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([scientificRepId, companyId])
  @@map("scientific_rep_companies")
}

// ─── ScientificRep ↔ CommercialRep ───────────────────────────
model ScientificRepCommercial {
  scientificRepId Int
  commercialRepId Int
  assignedAt      DateTime @default(now())

  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id], onDelete: Cascade)
  commercialRep MedicalRepresentative    @relation(fields: [commercialRepId], references: [id], onDelete: Cascade)

  @@id([scientificRepId, commercialRepId])
  @@map("scientific_rep_commercials")
}

// ─── Doctor Survey (السيرفي) ──────────────────────────────────
model Doctor {
  id           Int      @id @default(autoincrement())
  name         String
  specialty    String? // الاختصاص
  areaId       Int?
  pharmacyName String? // اسم الصيدلية المرتبطة
  targetItemId Int? // الإيتم المستهدف
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId     Int?
  user       User? @relation(fields: [userId], references: [id])
  area       Area? @relation(fields: [areaId], references: [id])
  targetItem Item? @relation(fields: [targetItemId], references: [id])

  planEntries PlanEntry[]
  visits      DoctorVisit[]

  @@index([userId])
  @@index([areaId])
  @@map("doctors")
}

// ─── Monthly Plan (البلان الشهري) ────────────────────────────
model MonthlyPlan {
  id               Int      @id @default(autoincrement())
  scientificRepId  Int
  month            Int // 1-12
  year             Int
  targetCalls      Int      @default(150)
  targetDoctors    Int      @default(75)
  notes            String?
  status           String   @default("draft") // "draft" | "active" | "completed"
  allowExtraVisits Boolean  @default(false) // السماح بكولات أطباء خارج البلان
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId         Int?
  user           User?                    @relation(fields: [userId], references: [id])
  assignedUserId Int? // rep user this plan is transferred/assigned to
  assignedUser   User?                    @relation("AssignedPlans", fields: [assignedUserId], references: [id])
  scientificRep  ScientificRepresentative @relation(fields: [scientificRepId], references: [id])

  entries PlanEntry[]

  @@unique([scientificRepId, month, year, userId])
  @@index([userId])
  @@index([assignedUserId])
  @@index([scientificRepId])
  @@map("monthly_plans")
}

// ─── Plan Entry: طبيب في البلان ──────────────────────────────
model PlanEntry {
  id           Int      @id @default(autoincrement())
  planId       Int
  doctorId     Int
  targetVisits Int      @default(2) // عادةً زيارتان
  createdAt    DateTime @default(now())

  plan        MonthlyPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  doctor      Doctor          @relation(fields: [doctorId], references: [id])
  visits      DoctorVisit[]
  targetItems PlanEntryItem[]

  @@unique([planId, doctorId])
  @@index([planId])
  @@index([doctorId])
  @@map("plan_entries")
}

// ─── Plan Entry ↔ Item (الايتمات المستهدفة لكل طبيب) ─────────
model PlanEntryItem {
  id          Int      @id @default(autoincrement())
  planEntryId Int
  itemId      Int
  createdAt   DateTime @default(now())

  planEntry PlanEntry @relation(fields: [planEntryId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([planEntryId, itemId])
  @@index([planEntryId])
  @@map("plan_entry_items")
}

// ─── Doctor Visit (زيارة فعلية) ──────────────────────────────
model DoctorVisit {
  id              Int      @id @default(autoincrement())
  doctorId        Int
  scientificRepId Int
  planEntryId     Int? // ربط بالبلان (اختياري)
  visitDate       DateTime
  itemId          Int?
  feedback        String   @default("pending")
  // "pending" | "writing" | "stocked" | "interested" | "not_interested" | "unavailable"
  notes           String?
  isDoubleVisit   Boolean  @default(false) // زيارة مزدوجة مع مدير/سوبرفايزر
  latitude        Float? // موقع GPS عند تسجيل الزيارة
  longitude       Float?
  createdAt       DateTime @default(now())

  userId        Int?
  user          User?                    @relation(fields: [userId], references: [id])
  doctor        Doctor                   @relation(fields: [doctorId], references: [id])
  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id])
  item          Item?                    @relation(fields: [itemId], references: [id])
  planEntry     PlanEntry?               @relation(fields: [planEntryId], references: [id])

  @@index([doctorId])
  @@index([scientificRepId])
  @@index([visitDate])
  @@index([userId])
  @@map("doctor_visits")
}

// ─── Pharmacy Visit (زيارة صيدلية) ──────────────────────────
model PharmacyVisit {
  id              Int      @id @default(autoincrement())
  pharmacyName    String
  areaId          Int?
  areaName        String?  // free-text fallback when areaId is null
  scientificRepId Int
  visitDate       DateTime
  notes           String?
  isDoubleVisit   Boolean  @default(false) // زيارة مزدوجة مع مدير/سوبرفايزر
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())

  userId        Int?
  user          User?                    @relation(fields: [userId], references: [id])
  area          Area?                    @relation(fields: [areaId], references: [id])
  scientificRep ScientificRepresentative @relation(fields: [scientificRepId], references: [id])
  items         PharmacyVisitItem[]

  @@index([userId])
  @@index([scientificRepId])
  @@index([visitDate])
  @@map("pharmacy_visits")
}

// ─── Pharmacy Visit Item (ايتمات زيارة الصيدلية) ─────────────
model PharmacyVisitItem {
  id              Int      @id @default(autoincrement())
  pharmacyVisitId Int
  itemId          Int?     // nullable: matched DB item; null when free-text only
  itemName        String?  // free-text item name when itemId is null
  notes           String?
  createdAt       DateTime @default(now())

  pharmacyVisit PharmacyVisit @relation(fields: [pharmacyVisitId], references: [id], onDelete: Cascade)
  item          Item?         @relation(fields: [itemId], references: [id])

  @@index([pharmacyVisitId])
  @@map("pharmacy_visit_items")
}

// ════════════════════════════════════════════════════════════
// MULTI-TENANT STRUCTURE — New Models
// ════════════════════════════════════════════════════════════

// ─── Super Admin (مالك التطبيق) ─────────────────────────────
model SuperAdmin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  isMaster     Boolean  @default(false) // true = المدير الرئيسي للسوبر أدمنيه
  displayName  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById   Int?
  createdBy     SuperAdmin?  @relation("AdminCreator", fields: [createdById], references: [id])
  createdAdmins SuperAdmin[] @relation("AdminCreator")

  @@map("super_admins")
}

// ─── Scientific Office (مكتب علمي) ──────────────────────────
model ScientificOffice {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies ScientificCompany[]
  users     User[]
  areas     Area[]              @relation("OfficeAreas")

  @@map("scientific_offices")
}

// ─── Scientific Company (شركة علمية داخل المكتب) ────────────
model ScientificCompany {
  id        Int      @id @default(autoincrement())
  name      String
  officeId  Int
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  office                 ScientificOffice        @relation(fields: [officeId], references: [id])
  items                  Item[]                  @relation("CompanyItems")
  lines                  ProductLine[]
  userCompanyAssignments UserCompanyAssignment[]

  @@unique([name, officeId])
  @@index([officeId])
  @@map("scientific_companies")
}

// ─── Product Line (لاين داخل الشركة) ────────────────────────
model ProductLine {
  id        Int      @id @default(autoincrement())
  name      String? // اختياري — مثل "لاين الجلدية"
  companyId Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company             ScientificCompany    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lineItems           ProductLineItem[]
  userLineAssignments UserLineAssignment[]

  @@index([companyId])
  @@map("product_lines")
}

// ─── Product Line ↔ Item ─────────────────────────────────────
model ProductLineItem {
  lineId Int
  itemId Int

  line ProductLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  item Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([lineId, itemId])
  @@map("product_line_items")
}

// ─── User ↔ Company Assignment ───────────────────────────────
model UserCompanyAssignment {
  userId     Int
  companyId  Int
  assignedAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company ScientificCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@map("user_company_assignments")
}

// ─── User ↔ Line Assignment ──────────────────────────────────
model UserLineAssignment {
  userId     Int
  lineId     Int
  assignedAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  line ProductLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@id([userId, lineId])
  @@map("user_line_assignments")
}

// ─── User ↔ Item Assignment (ايتمات مخصصة بدون لاين) ────────
model UserItemAssignment {
  userId     Int
  itemId     Int
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("user_item_assignments")
}

// ─── User ↔ Area Assignment ──────────────────────────────────
model UserAreaAssignment {
  userId     Int
  areaId     Int
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
  @@map("user_area_assignments")
}

// ─── User Manager Assignment (التسلسل الوظيفي — مرن) ────────
model UserManagerAssignment {
  userId     Int // الموظف
  managerId  Int // المدير
  assignedAt DateTime @default(now())

  user    User @relation("UserSubordinates", fields: [userId], references: [id], onDelete: Cascade)
  manager User @relation("UserManagers", fields: [managerId], references: [id], onDelete: Cascade)

  @@id([userId, managerId])
  @@map("user_manager_assignments")
}

// ─── User Interaction Permission (من يتفاعل مع بيانات من) ───
model UserInteractionPermission {
  actorId  Int // من يملك الصلاحية
  targetId Int // صاحب البيانات
  // JSON array: ["orders","reports","plans","visits","invoices"]
  canTypes String @default("[]")

  actor  User @relation("InteractionActor", fields: [actorId], references: [id], onDelete: Cascade)
  target User @relation("InteractionTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([actorId, targetId])
  @@map("user_interaction_permissions")
}

// ─── Invoice Sheet (كشف الاستحصال — المندوب التجاري) ────────
model InvoiceSheet {
  id          Int      @id @default(autoincrement())
  repId       Int // المندوب التجاري
  companyId   Int? // الشركة المعنية
  areaId      Int? // المنطقة
  title       String?
  notes       String?
  status      String   @default("active") // "active" | "completed" | "archived"
  totalAmount Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rep     User           @relation(fields: [repId], references: [id])
  entries InvoiceEntry[]

  @@index([repId])
  @@index([status])
  @@map("invoice_sheets")
}

// ─── Invoice Entry (صيدلية في كشف الاستحصال) ────────────────
model InvoiceEntry {
  id            Int       @id @default(autoincrement())
  sheetId       Int
  pharmacyName  String
  orderRef      String? // رقم الطلبية
  orderDetails  String? // تفاصيل إضافية (JSON)
  amount        Float
  isCollected   Boolean   @default(false)
  collectedAt   DateTime?
  collectedById Int? // من أشّر على الاستحصال
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sheet InvoiceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId])
  @@index([isCollected])
  @@map("invoice_entries")
}
