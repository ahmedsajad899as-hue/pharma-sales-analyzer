model SalesDataFile {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String
  uploadedAt DateTime @default(now())
  fixedCols  Json     // string[]
  areaCols   Json     // ColMeta[]
  rows       Json     // Record<string,string>[]
  regions    Json     // string[]
  sourceFileIds Json? // number[] (for merged files)
  createdAt  DateTime @default(now())
