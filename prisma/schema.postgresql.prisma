// ─── Doctor Archive Entry (أرشيف السيرفي — يدوي لكل مستخدم) ─
model DoctorArchiveEntry {
  id                   Int      @id @default(autoincrement())
  userId               Int
  masterSurveyDoctorId Int
  isVisited            Boolean  @default(false)
  isWriting            Boolean  @default(false)
  visitItems           String?
  writingItems         String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterSurveyDoctor MasterSurveyDoctor @relation(fields: [masterSurveyDoctorId], references: [id], onDelete: Cascade)

  @@unique([userId, masterSurveyDoctorId])
  @@index([userId])
  @@map("doctor_archive_entries")
}
